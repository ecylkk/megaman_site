<!-- app/views/pages/select.html.erb -->
<%# Pixel Mega Man 3 style Stage Select with avatar center, hover activation, WASD + Arrow nav %>

<style>
:root {
  --bg: #329ef7;
  --accent: #39f;
  --locked: #444;
}

html, body {
  height: 100%;
  margin: 0;
  font-family: 'Press Start 2P', 'DotGothic16', 'SimSun', '宋体', monospace;
  background: var(--bg);
  color: #dfe7ff;
  overflow: hidden; /* 绝对禁止滚动 */
  display: flex;
  align-items: center;
  justify-content: center;
  -webkit-font-smoothing: none;
  font-smooth: never;
}
body { padding: 0; }

h1, .hint, button { font-family: 'Press Start 2P', 'DotGothic16', 'SimSun', '宋体', monospace !important; }

h1, .hint, button { font-family: 'Press Start 2P', 'DotGothic16', 'SimSun', '宋体', monospace !important; }

.container { 
  max-width: 960px; 
  width: 100%;
  margin: 0 auto; 
  padding: 0 30px;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

h1 {
  text-align: center;
  font-size: 18px;
  margin-bottom: 10px;
  letter-spacing: 2px;
}

/* ===== Grid ===== */
.grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18px;     /* 恢复原来宽敞的间隙 */
  margin-top: 8px;
  width: 100%;
}

/* ===== Each cell ===== */
.boss {
  background: #0e1a2e; /* 恢复海军蓝底色 */
  border: 3px solid rgba(255,255,255,0.15);
  padding: 12px;
  height: 160px; /* 【核心修复】固定 160px 高度，绝不压扁！ */
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  position: relative;
  cursor: pointer;
  transition: transform .08s ease, box-shadow .12s ease, border-color .12s;
  user-select: none;
  font-family: 'Press Start 2P', 'DotGothic16', 'SimSun', '宋体', monospace;
  box-sizing: border-box;
}

/* ===== Hover / Selected activation — 和蓝色背景明显区分 ===== */
.boss.selected,
.boss:hover {
  opacity: 1 !important;
  filter: none !important;
  transform: translateY(-8px);
  border-color: #fff;
  background: rgba(0, 0, 0, 0.35);
  box-shadow:
    0 0 18px rgba(255, 255, 255, 0.5),
    0 12px 22px rgba(0, 0, 0, 0.6),
    inset 0 0 12px rgba(57, 153, 255, 0.3);
}

.thumb {
  width: 82px;
  height: 82px;
  border-radius: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
  color: #fff;
  box-shadow: inset 0 -6px 0 rgba(0,0,0,0.25);
}

.boss.unlocked .thumb { background: linear-gradient(180deg, #222, #111); }
.boss.locked .thumb { background: linear-gradient(180deg, #222, #111); border: 2px dashed var(--locked); }

.boss.locked {
  opacity: 0.55;
  filter: grayscale(.5);
  box-shadow: none;
  cursor: not-allowed;
}

.name { margin-top: 8px; font-size: 12px; letter-spacing: 1px; text-align: center; }
.sub { font-size: 10px; opacity: .88; margin-top: 4px; }

.boss.selected .name,
.boss:hover .name { color: #fff; }
.boss.selected .sub,
.boss:hover .sub { color: #adf; opacity: 1; }

/* ===== Center avatar cell ===== */
.avatar-img {
  width: 82px;
  height: 82px;
  border-radius: 6px;
  object-fit: cover;
  border: 2px solid #fff;
  transition: filter 0.2s;
  box-sizing: border-box;
}

.boss.selected .avatar-img,
.boss:hover .avatar-img {
  filter: brightness(1.2);
}

.avatar-name {
  margin-top: 6px;
  font-size: 10px;
  letter-spacing: 2px;
  font-family: 'Press Start 2P', 'DotGothic16', 'SimSun', '宋体', monospace;
  color: #fff;
}

/* ===== Controls ===== */
.controls {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16px;
  gap: 12px;
  /* 移除 flex-wrap: wrap，防止因为折行导致 UI 被垂直撑大 */
  flex-wrap: nowrap;
  width: 100%;
}

.bgm-btn, .clear-all {
  font-family: 'Press Start 2P', monospace;
  font-size: 10px;
  padding: 0;
  width: 120px;
  height: 32px; /* 最彻底防御：锁死高度，不管特殊字符怎么撑都不准形变 */
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 6px;
  cursor: pointer;
  box-sizing: border-box;
  flex-shrink: 0;
}
.bgm-btn { background: #0b1320; border: 1px solid rgba(255,255,255,0.06); color: #cfe; }
.clear-all { background: #111; border: 1px solid rgba(255,255,255,0.04); color: #f99; }

.hint { font-size: 11px; opacity: .92; }
</style>

<div class="container">
  <h1>STAGE SELECT v7</h1>

  <div id="grid" class="grid">
    <% boss_idx = 0 %>
    <% 9.times do |pos| %>
      <% if pos == 4 %>
        <%# === Center: Player Avatar === %>
        <div tabindex="0" role="button" class="boss avatar-cell unlocked" data-id="kai" data-idx="4">
          <%= image_tag 'kai.jpg', class: 'avatar-img', alt: 'KAI' %>
          <div class="avatar-name">KAI</div>
        </div>
      <% else %>
        <% s = @stages[boss_idx] %>
        <% unlocked = true %>
        <div tabindex="0" role="button" class="boss <%= unlocked ? 'unlocked' : 'locked' %>" data-id="<%= s[:id] %>" data-idx="<%= pos %>">
          <div class="thumb"><%= unlocked ? "◎" : "×" %></div>
          <div class="name"><%= s[:name] %></div>
          <div class="sub"><%= s[:subtitle] %></div>
        </div>
        <% boss_idx += 1 %>
      <% end %>
    <% end %>
  </div>

  <div class="controls">
    <div class="hint">W↑ A← S↓ D→ / Arrow Keys to navigate, Enter to open</div>
    <div style="display:flex;gap:6px;">
      <button id="bgmToggle" class="bgm-btn">♪ BGM</button>
      <button id="clearData" class="clear-all" title="清空已通关状态">CLEAR</button>
    </div>
  </div>
</div>

<audio id="bgm" preload="auto">
  <source src="<%= asset_path 'select_music.mp3' %>" type="audio/mpeg">
</audio>

<script>
(function(){
  const grid = document.getElementById('grid')
  const bosses = Array.from(grid.querySelectorAll('.boss'))
  const bgm = document.getElementById('bgm')
  const btn = document.getElementById('bgmToggle')
  const clearBtn = document.getElementById('clearData')

  // keyboard selection
  let selected = 4  // start on avatar (center)
  
  const avatarCell = bosses[4]
  if (avatarCell) {
    avatarCell.style.transition = 'transform 0.3s cubic-bezier(0.25, 0.8, 0.25, 1)'
    avatarCell.style.transformStyle = 'preserve-3d'
  }

  function updateAvatarTilt(idx) {
    if (!avatarCell) return
    let rx = 0
    let ry = 0
    const tilt = 14 // 倾斜角度，可以根据喜好调整
    
    if (idx !== 4) {
      const row = Math.floor(idx / 3)
      const col = idx % 3
      
      // 反转算法：根据你的反馈将倾斜方向完全相反，产生按压/被推开的物理感
      if (row === 0) rx = tilt
      else if (row === 2) rx = -tilt
      
      if (col === 0) ry = -tilt
      else if (col === 2) ry = tilt
      
      // 掠过其他框时：中间产生3D偏转
      avatarCell.style.transform = `perspective(800px) rotateX(${rx}deg) rotateY(${ry}deg) translateZ(10px)`
    } else {
      // 掠过自己时：恢复原始，稍微浮起保持和其他框一样的悬停凸出
      avatarCell.style.transform = `perspective(800px) rotateX(0deg) rotateY(0deg) translateZ(0) translateY(-8px)`
    }
  }

  if (bosses.length > 0) {
    bosses[selected].classList.add('selected')
    updateAvatarTilt(selected)
  }

  function selectIndex(i) {
    bosses[selected].classList.remove('selected')
    selected = (i + bosses.length) % bosses.length
    bosses[selected].classList.add('selected')
    updateAvatarTilt(selected)
    try { bosses[selected].focus() } catch(e) {}
  }

  // Arrow keys + WASD navigation
  window.addEventListener('keydown', (e) => {
    const cols = 3
    const key = e.key.toLowerCase()
    const navKeys = ['arrowright','arrowleft','arrowup','arrowdown','enter','w','a','s','d']
    if (navKeys.includes(key)) e.preventDefault()

    if (key === 'arrowright' || key === 'd') selectIndex(selected + 1)
    if (key === 'arrowleft'  || key === 'a') selectIndex(selected - 1)
    if (key === 'arrowup'    || key === 'w') selectIndex(selected - cols)
    if (key === 'arrowdown'  || key === 's') selectIndex(selected + cols)
    if (key === 'enter') openBoss(bosses[selected])
  })

  bosses.forEach((b, idx) => {
    b.addEventListener('click', () => openBoss(b))
    b.addEventListener('mouseenter', () => {
      bosses[selected].classList.remove('selected')
      selected = idx
      bosses[selected].classList.add('selected')
      updateAvatarTilt(idx)
      triggerBGMOnce()
    })
    b.addEventListener('mouseleave', () => {
      // Keep selected class for keyboard tracking
    })
  })

  // 当鼠标离开整个九宫格时，重置倾斜和浮动效果，回到静止状态
  grid.addEventListener('mouseleave', () => {
    if (avatarCell) {
      avatarCell.style.transform = `perspective(800px) rotateX(0deg) rotateY(0deg) translateZ(0) translateY(0)`
    }
  })

  function openBoss(bossEl) {
    if (!bossEl) return
    if (bossEl.classList.contains('locked')) {
      bossEl.animate([
        { transform: 'translateX(0)' },
        { transform: 'translateX(-4px)' },
        { transform: 'translateX(4px)' },
        { transform: 'translateX(-2px)' },
        { transform: 'translateX(0)' }
      ], { duration: 250 })
      return
    }
    // Flash effect before navigation
    bossEl.style.filter = 'brightness(3)'
    bossEl.style.transition = 'filter 0.1s'
    setTimeout(() => {
      window.location.href = "/stage/" + bossEl.dataset.id
    }, 200)
  }

  // single-play-on-hover BGM
  let bgmPlayed = false
  bgm.volume = 0.2
  bgm.loop = false

  async function triggerBGMOnce() {
    if (bgmPlayed) return
    try {
      await bgm.play()
      bgmPlayed = true
    } catch(err) {
      console.warn('BGM autoplay blocked, waiting for user interaction')
      window.addEventListener('click', playBGMOnGestureOnce, { once: true })
      window.addEventListener('keydown', playBGMOnGestureOnce, { once: true })
    }
  }
  async function playBGMOnGestureOnce() {
    if (bgmPlayed) return
    try { await bgm.play(); bgmPlayed = true } catch(e) { console.warn('BGM failed', e) }
  }

  // PLAY/PAUSE button
  btn.addEventListener('click', async ev => {
    ev.preventDefault()
    try {
      if (bgm.paused) { await bgm.play(); btn.textContent = '⏸ BGM' }
      else { bgm.pause(); btn.textContent = '♪ BGM' }
    } catch(err) { console.warn('button play error', err) }
  })

  // CLEAR ALL
  if (clearBtn) {
    clearBtn.addEventListener('click', async () => {
      if (!confirm('确定要清空所有已通关状态吗？')) return
      try {
        const res = await fetch('/clear_stage', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': '<%= form_authenticity_token %>' },
          body: JSON.stringify({ stage_id: '__clear_all__' })
        })
        if (res.ok) location.reload()
        else alert('清空失败')
      } catch(e) { console.error(e); alert('请求失败') }
    })
  }

  // 修复浏览器“回退”按钮导致的样式残留（消除返回后的闪烁和发虚bug）
  window.addEventListener('pageshow', (e) => {
    if (e.persisted) {
      bosses.forEach(b => {
        b.style.filter = ''
        b.style.transition = ''
      })
    }
  })
})();
</script>
